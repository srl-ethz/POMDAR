<mujoco model="g8">

  <asset>
    <material name="object_material" rgba="1 1 1 1" shininess="0.3"/>

    <mesh name="g8_base_plate_visual" file="g8_base_plate_visual.stl" scale="1 1 1"/>
    <mesh name="g_plate_collision_part1" file="g_plate_collision_part1.stl" scale="1 1 1"/>
    <mesh name="g_plate_collision_part2" file="g_plate_collision_part2.stl" scale="1 1 1"/>
    <mesh name="g_plate_collision_part3" file="g_plate_collision_part3.stl" scale="1 1 1"/>
    <mesh name="g8_bracket_collision_part1" file="g8_bracket_collision_part1.stl" scale="1 1 1"/>
    <mesh name="g8_bracket_collision_part2" file="g8_bracket_collision_part2.stl" scale="1 1 1"/>
    <mesh name="g8_bracket_collision_part3" file="g8_bracket_collision_part3.stl" scale="1 1 1"/>
    <mesh name="g8_bracket_collision_part4" file="g8_bracket_collision_part4.stl" scale="1 1 1"/>


    <mesh name="g8_object_visual" file="g8_object_visual.stl" scale="1 1 1"/>
    <mesh name="g8_object_collision_part1" file="g8_object_collision_part1.stl" scale="1 1 1"/>
    <mesh name="g8_object_collision_part2" file="g8_object_collision_part2.stl" scale="1 1 1"/>
    <mesh name="g8_object_collision_part3" file="g8_object_collision_part3.stl" scale="1 1 1"/>
    <mesh name="g8_object_collision_part4" file="g8_object_collision_part4.stl" scale="1 1 1"/>
    
  </asset>

  <default>
    <default class="visual">
      <geom contype="0" conaffinity="0" group="2"/>
    </default>
    <default class="collision">
      <geom group="3" solimp="0.5 0.99 0.0001" solref="0.005 1"/>
    </default>
  </default>

  <worldbody>
    <body name="base_plate" pos="0 0 0">
      <geom name="g8_base_plate_visual" type="mesh" mesh="g8_base_plate_visual" rgba="0.3 0.3 0.3 1" mass="0" class="visual"/>
      <geom name="g_plate_collision_part1" type="mesh" mesh="g_plate_collision_part1" class="collision" density="248"/>
      <geom name="g_plate_collision_part2" type="mesh" mesh="g_plate_collision_part2" class="collision" density="248"/>
      <!-- <geom name="g_plate_collision_part3" type="mesh" mesh="g_plate_collision_part3" class="collision" density="248"/> -->
      <geom size="0.1265 0.1063 0.007"  pos="0 0 0.007" type="box" density="248" class="collision"/>
      <geom name="g8_bracket_collision_part1" type="mesh" mesh="g8_bracket_collision_part1" class="collision" density="248"/>
      <geom name="g8_bracket_collision_part2" type="mesh" mesh="g8_bracket_collision_part2" class="collision" density="248"/>
      <geom name="g8_bracket_collision_part3" type="mesh" mesh="g8_bracket_collision_part3" class="collision" density="248"/>
      <geom name="g8_bracket_collision_part4" type="mesh" mesh="g8_bracket_collision_part4" class="collision" density="248"/>
    </body>

    <body name="g8_object" pos="0 0 0">
      <joint name="g8_free_joint" type="free"/>
      <geom name="g8_object_visual" type="mesh" mesh="g8_object_visual" material="object_material" mass="0" class="visual"/>
      <!-- unexpected slide on the bas plane will occur if using mesh -->
      <!-- <geom name="g8_object_collision_part1" type="mesh" mesh="g8_object_collision_part1" class="collision" mass="0.1"/> -->
      <geom size="0.0175 0.0573 0.0025"  pos="0.105 0 0.0165" type="box" density="248" class="collision"/>
      <geom name="g8_object_collision_part2" type="mesh" mesh="g8_object_collision_part2" class="collision" density="248"/>
      <geom name="g8_object_collision_part3" type="mesh" mesh="g8_object_collision_part3" class="collision" density="248"/>
      <geom name="g8_object_collision_part4" type="mesh" mesh="g8_object_collision_part4" class="collision" density="248"/>
    </body>
    
  </worldbody>
</mujoco>