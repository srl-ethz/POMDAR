        def "disk_rod" (
            prepend apiSchemas = ["PhysicsRigidBodyAPI"]
        )
        {
            over "round_disk" (
                prepend apiSchemas = ["PhysicsCollisionAPI", "MjcCollisionAPI", "PhysicsMeshCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
            )
            {
                rel material:binding:physics = </sim_pomdar_scene/Physics/PhysicsMaterial>
                uniform token physics:approximation = "convexHull"
                float physics:mass = 0.05
            }

            over "Cylinder" (
                prepend apiSchemas = ["PhysicsCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
            )
            {
                rel material:binding:physics = </sim_pomdar_scene/Physics/PhysicsMaterial>
                float physics:density = 248
            }

            over "Cylinder_1" (
                prepend apiSchemas = ["PhysicsCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
            )
            {
                rel material:binding:physics = </sim_pomdar_scene/Physics/PhysicsMaterial>
                uniform int mjc:group = 2
                bool physics:collisionEnabled = 0
                float physics:mass = 0.05
            }

            over "Box" (
                prepend apiSchemas = ["PhysicsCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
            )
            {
                rel material:binding:physics = </sim_pomdar_scene/Physics/PhysicsMaterial>
                float physics:density = 248
            }

            def PhysicsPrismaticJoint "disk_rod_slide_joint" (
                prepend apiSchemas = ["MjcJointAPI"]
            )
            {
                uniform double mjc:damping = 100
                uniform token physics:axis = "Z"
                rel physics:body0 = </sim_pomdar_scene>
                rel physics:body1 = </sim_pomdar_scene/Geometry/disk_rod>
                point3f physics:localPos0 = (0, 0, 0.233)
                point3f physics:localPos1 = (0, 0, 0)
                quatf physics:localRot0 = (1, 0, 0, 0)
                quatf physics:localRot1 = (1, 0, 0, 0)
                float physics:lowerLimit = -0.01
                float physics:upperLimit = 1
            }

            def PhysicsRevoluteJoint "disk_rod_hinge_joint" (
                prepend apiSchemas = ["MjcJointAPI"]
            )
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </sim_pomdar_scene>
                rel physics:body1 = </sim_pomdar_scene/Geometry/disk_rod>
                point3f physics:localPos0 = (0, 0, 0.233)
                point3f physics:localPos1 = (0, 0, 0)
                quatf physics:localRot0 = (1, 0, 0, 0)
                quatf physics:localRot1 = (1, 0, 0, 0)
            }
        }

        def "table_body" (
            prepend apiSchemas = ["PhysicsRigidBodyAPI"]
        )
        {
            over "table_top" (
                prepend apiSchemas = ["PhysicsCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
            )
            {
                rel material:binding:physics = </sim_pomdar_scene/Physics/PhysicsMaterial>
                float physics:mass = 10
            }

            over "leg1" (
                prepend apiSchemas = ["PhysicsCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
            )
            {
                rel material:binding:physics = </sim_pomdar_scene/Physics/PhysicsMaterial>
                float physics:density = 700
            }

            over "leg2" (
                prepend apiSchemas = ["PhysicsCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
            )
            {
                rel material:binding:physics = </sim_pomdar_scene/Physics/PhysicsMaterial>
                float physics:density = 700
            }

            over "leg3" (
                prepend apiSchemas = ["PhysicsCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
            )
            {
                rel material:binding:physics = </sim_pomdar_scene/Physics/PhysicsMaterial>
                float physics:density = 700
            }

            over "leg4" (
                prepend apiSchemas = ["PhysicsCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
            )
            {
                rel material:binding:physics = </sim_pomdar_scene/Physics/PhysicsMaterial>
                float physics:density = 700
            }

            def PhysicsFixedJoint "PhysicsFixedJoint"
            {
                rel physics:body0 = </sim_pomdar_scene>
                rel physics:body1 = </sim_pomdar_scene/Geometry/table_body>
                point3f physics:localPos0 = (0, 0, -0.02)
                point3f physics:localPos1 = (0, 0, 0)
                quatf physics:localRot0 = (1, 0, 0, 0)
                quatf physics:localRot1 = (1, 0, 0, 0)
            }
        }
    }
}

def PhysicsScene "PhysicsScene" (
    prepend apiSchemas = ["MjcSceneAPI"]
)
{
    uniform token mjc:compiler:angle = "radian"
    uniform token mjc:compiler:inertiaFromGeom = "true"
    uniform token mjc:option:cone = "elliptic"
    uniform double mjc:option:impratio = 2
    uniform token mjc:option:integrator = "implicitfast"
    uniform int mjc:option:iterations = 200
    uniform double mjc:option:timestep = 0.001
    uniform double mjc:option:tolerance = 1e-10
    vector3f physics:gravityDirection = (0, 0, -1)
    float physics:gravityMagnitude = 9.81
}

